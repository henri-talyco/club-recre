---
import BaseLayout from "../../layouts/BaseLayout.astro";

const marques = [
  { slug: "oshkosh-bgosh", name: "OshKosh B'Gosh", country: "USA", years: "1895-aujourd'hui", peak: "1980-1995", style: "Workwear américain" },
  { slug: "petit-bateau", name: "Petit Bateau", country: "France", years: "1893-aujourd'hui", peak: "1960-1995", style: "Marinière française" },
  { slug: "catimini", name: "Catimini", country: "France", years: "1972-aujourd'hui", peak: "1985-1998", style: "Imprimés colorés" },
  { slug: "cyrillus", name: "Cyrillus", country: "France", years: "1977-aujourd'hui", peak: "1990-2000", style: "Classique chic" },
  { slug: "sergent-major", name: "Sergent Major", country: "France", years: "1986-aujourd'hui", peak: "1995-2005", style: "Sportswear casual" },
  { slug: "jacadi", name: "Jacadi", country: "France", years: "1976-aujourd'hui", peak: "1985-2000", style: "Premium classique" },
  { slug: "dpam", name: "DPAM", country: "France", years: "1988-aujourd'hui", peak: "1990-2000", style: "Couleurs accessibles" },
  { slug: "naf-naf-kids", name: "Naf Naf Kids", country: "France", years: "années 80-2010", peak: "1990-2000", style: "Coupe-vents fluo" },
  { slug: "lacoste-enfant", name: "Lacoste Enfant", country: "France", years: "1933-aujourd'hui", peak: "1980-2000", style: "Polo iconique" },
  { slug: "disney-vintage", name: "Disney Vintage", country: "USA", years: "années 70-aujourd'hui", peak: "1985-2000", style: "Pop culture" },
  { slug: "kookai-kids", name: "Kookaï Kids", country: "France", years: "années 90", peak: "1995-2005", style: "Mode girly 90s" },
  { slug: "marese", name: "Marèse", country: "France", years: "1957-aujourd'hui", peak: "1985-2000", style: "Couture enfant" },
];
---

<BaseLayout
  title="Marques vintage enfant — encyclopédie Club Récré"
  description="L'encyclopédie complète des marques vintage enfant des années 80-90 : OshKosh, Petit Bateau, Catimini, Cyrillus, Lacoste enfant... Histoire, époque dorée, pièces signatures."
>
  <header class="container-narrow py-16 text-center">
    <p class="section-label">Encyclopédie</p>
    <h1 class="font-fraunces font-bold leading-[1.05] tracking-[-0.02em]" style="font-size: clamp(2.5rem, 6vw, 4rem);">
      Les marques vintage enfant.
    </h1>
    <p class="text-lg max-w-[640px] mx-auto mt-4 opacity-90">
      Toutes les marques vintage enfant des années 80-90 à connaître. Histoire, époque dorée, pièces à chercher, comment authentifier.
    </p>
  </header>

  <section class="container-narrow pb-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {marques.map((m) => (
        <a href={`/marques/${m.slug}`} class="card-hover bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 block">
          <div class="aspect-[4/3] flex items-center justify-center font-bagel text-2xl text-center p-6 leading-tight"
               style="background: linear-gradient(135deg, #d4a373, #b87333); color: #F5E9D3;">
            {m.name}
          </div>
          <div class="p-6">
            <div class="text-[11px] uppercase tracking-[0.25em] text-orange-sirop font-bold mb-2">
              {m.country} · {m.style}
            </div>
            <h2 class="font-fraunces text-xl font-semibold leading-tight mb-2">{m.name}</h2>
            <p class="text-sm text-noir-reglisse opacity-80">
              Fondée en {m.years.split("-")[0]} · Époque dorée {m.peak}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
