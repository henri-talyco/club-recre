---
import BaseLayout from "../layouts/BaseLayout.astro";
import Newsletter from "../components/Newsletter.astro";

const selectionMode = [
  { name: "Salopette OshKosh denim 1989", brand: "OshKosh B'Gosh", taille: "18-24 mois", prix: "24€", url: "https://www.vinted.fr", img: "/img/articles/mercredi-apres-midi-90s.jpg" },
  { name: "Chemise liberty rose vintage", brand: "Vintage", taille: "24-36 mois", prix: "14€", url: "https://www.vinted.fr", img: "/img/articles/mercredi-apres-midi-90s.jpg" },
  { name: "Coupe-vent rose fluo 90s", brand: "Vintage", taille: "3 ans", prix: "22€", url: "https://www.vinted.fr", img: "/img/articles/jeux-cour-recre.jpg" },
  { name: "Salopette toile jaune", brand: "Vintage", taille: "12-18 mois", prix: "18€", url: "https://www.vinted.fr", img: "/img/articles/mercredi-apres-midi-90s.jpg" },
];

const selectionJouets = [
  { name: "Set Playmobil Chevaliers 5783", epoque: "1992", etat: "Très bon état", prix: "35€", url: "https://www.vinted.fr", img: "/img/articles/jouets-vintage-selection.jpg" },
  { name: "Téléphone Fisher Price Chatter rouge", epoque: "1985", etat: "Bon état", prix: "28€", url: "https://www.vinted.fr", img: "/img/articles/jouets-vintage-selection.jpg" },
  { name: "Polly Pocket compact original Bluebird", epoque: "1994", etat: "Très bon état", prix: "45€", url: "https://www.vinted.fr", img: "/img/articles/jouets-vintage-selection.jpg" },
  { name: "Lot 30 Playmobil pirates + accessoires", epoque: "1990s", etat: "Bon état", prix: "52€", url: "https://www.vinted.fr", img: "/img/articles/jouets-vintage-selection.jpg" },
  { name: "Tamagotchi P2 original 1997", epoque: "1997", etat: "Fonctionnel", prix: "65€", url: "https://www.vinted.fr", img: "/img/articles/jouets-vintage-selection.jpg" },
  { name: "Cubes en bois Brio (lot 50)", epoque: "1990s", etat: "Très bon état", prix: "32€", url: "https://www.vinted.fr", img: "/img/articles/jouets-vintage-selection.jpg" },
];

const selectionLivres = [
  { name: "Le Petit Nicolas (édition originale)", auteur: "Sempé/Goscinny", annee: "1985", prix: "8€", url: "https://www.vinted.fr" },
  { name: "Astrapi (lot 12 numéros 1992)", auteur: "Bayard", annee: "1992", prix: "15€", url: "https://www.vinted.fr" },
  { name: "Tintin — Coke en stock", auteur: "Hergé", annee: "1988 réédition", prix: "12€", url: "https://www.vinted.fr" },
  { name: "Charlie et la Chocolaterie", auteur: "Roald Dahl", annee: "1990", prix: "6€", url: "https://www.vinted.fr" },
];
---

<BaseLayout
  title="Sélections du mois — Mode, jouets et livres vintage Club Récré"
  description="Notre sélection mensuelle de pièces vintage chinées à la main : vêtements enfant 90s, jouets vintage, livres jeunesse. Tout est testé, lavé, photographié."
>
  <header class="container-narrow py-16 text-center">
    <p class="section-label">Sélection du mois · Mai 2026</p>
    <h1 class="font-fraunces font-bold leading-[1.05] tracking-[-0.02em]" style="font-size: clamp(2.5rem, 6vw, 4rem);">
      La curation Club Récré.
    </h1>
    <p class="text-lg max-w-[680px] mx-auto mt-4 opacity-90">
      Chaque mois, on chine et on sélectionne des pièces vintage qu'on a vraiment envie de transmettre à nos propres enfants. Tout est testé, lavé, photographié à la main.
    </p>
    <p class="font-fraunces italic text-vert-recre mt-6">
      "Si on n'en achèterait pas pour son propre enfant, ça ne rentre pas dans la sélection."
    </p>
  </header>

  <!-- MODE -->
  <section class="container-narrow pb-12">
    <div class="border-b-2 border-vert-recre pb-3 mb-8 flex justify-between items-end flex-wrap gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-orange-sirop font-bold mb-1">01</p>
        <h2 class="font-fraunces text-3xl md:text-4xl font-bold">Mode vintage enfant</h2>
      </div>
      <p class="text-sm text-gris-cartable">{selectionMode.length} pièces</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {selectionMode.map((p) => (
        <div class="bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 card-hover">
          <div class="aspect-square overflow-hidden">
            <img src={p.img} alt={p.name} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-5">
            <p class="text-[11px] uppercase tracking-[0.2em] text-orange-sirop font-bold mb-1">{p.brand}</p>
            <h3 class="font-fraunces text-lg font-semibold leading-tight mb-2">{p.name}</h3>
            <p class="text-sm text-gris-cartable mb-3">{p.taille}</p>
            <div class="flex justify-between items-center">
              <span class="font-fraunces text-xl font-bold">{p.prix}</span>
              <a href={p.url} target="_blank" rel="noopener" class="text-xs uppercase tracking-[0.15em] font-bold text-orange-sirop hover:text-vert-recre">Voir →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- JOUETS -->
  <section class="container-narrow pb-12">
    <div class="border-b-2 border-vert-recre pb-3 mb-8 flex justify-between items-end flex-wrap gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-orange-sirop font-bold mb-1">02</p>
        <h2 class="font-fraunces text-3xl md:text-4xl font-bold">Jouets vintage 90s</h2>
      </div>
      <p class="text-sm text-gris-cartable">{selectionJouets.length} pièces</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {selectionJouets.map((p) => (
        <div class="bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 card-hover">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={p.img} alt={p.name} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-5">
            <p class="text-[11px] uppercase tracking-[0.2em] text-orange-sirop font-bold mb-1">{p.epoque}</p>
            <h3 class="font-fraunces text-lg font-semibold leading-tight mb-2">{p.name}</h3>
            <p class="text-sm text-gris-cartable mb-3">{p.etat}</p>
            <div class="flex justify-between items-center">
              <span class="font-fraunces text-xl font-bold">{p.prix}</span>
              <a href={p.url} target="_blank" rel="noopener" class="text-xs uppercase tracking-[0.15em] font-bold text-orange-sirop hover:text-vert-recre">Voir →</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- LIVRES -->
  <section class="container-narrow pb-12">
    <div class="border-b-2 border-vert-recre pb-3 mb-8 flex justify-between items-end flex-wrap gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-orange-sirop font-bold mb-1">03</p>
        <h2 class="font-fraunces text-3xl md:text-4xl font-bold">Livres jeunesse vintage</h2>
      </div>
      <p class="text-sm text-gris-cartable">{selectionLivres.length} livres</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {selectionLivres.map((p) => (
        <div class="bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 card-hover p-6 flex justify-between items-center gap-4">
          <div>
            <p class="text-[11px] uppercase tracking-[0.2em] text-orange-sirop font-bold mb-1">{p.auteur} · {p.annee}</p>
            <h3 class="font-fraunces text-lg font-semibold leading-tight">{p.name}</h3>
          </div>
          <div class="text-right shrink-0">
            <span class="font-fraunces text-xl font-bold block">{p.prix}</span>
            <a href={p.url} target="_blank" rel="noopener" class="text-xs uppercase tracking-[0.15em] font-bold text-orange-sirop hover:text-vert-recre">Voir →</a>
          </div>
        </div>
      ))}
    </div>
  </section>

  <Newsletter variant="card" />

  <section class="container-narrow pb-20 text-center">
    <p class="font-fraunces italic text-xl text-vert-recre max-w-[640px] mx-auto">
      Une nouvelle sélection chaque mois. Les abonnés du Club la reçoivent <strong>24h en avance</strong> par email.
    </p>
  </section>
</BaseLayout>
