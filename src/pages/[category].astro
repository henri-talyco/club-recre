---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const categories = [
    {
      slug: "activites",
      pillar: "activites",
      label: "Activités",
      subtitle: "Choisis une ville, l'âge de ton enfant, et trouve la sortie qui sauve le mercredi.",
    },
    { slug: "education", pillar: "education", label: "Éducation", subtitle: "Élever un enfant moins connecté, plus libre, plus autonome." },
    { slug: "lifestyle", pillar: "lifestyle", label: "Lifestyle", subtitle: "Chambre, déco, recettes, organisation du quotidien." },
    { slug: "jouets-vintage", pillar: "jouets-vintage", label: "Jouets vintage", subtitle: "Playmobil, Fisher Price, Polly Pocket. Les jouets qu'on transmet." },
    { slug: "vintage", pillar: "looks", label: "Mode vintage", subtitle: "OshKosh, Petit Bateau, Catimini. Habiller son enfant avec caractère." },
  ];
  return categories.map((cat) => ({ params: { category: cat.slug }, props: cat }));
}

const { pillar, label, subtitle } = Astro.props;

const articles = await getCollection("articles");
const isActivities = pillar === "activites";

// Filtrage : pour 'vintage' on prend looks + pieces-histoires + marques + epoques + conseils-guides + drops
const matchesPillar = (articlePillar: string) => {
  if (pillar === "looks") {
    return ["looks", "pieces-histoires", "marques", "epoques", "conseils-guides", "drops"].includes(articlePillar);
  }
  return articlePillar === pillar;
};

const filtered = articles
  .filter((a) => matchesPillar(a.data.pillar))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pillarLabels: Record<string, string> = {
  activites: "Activités",
  education: "Éducation",
  lifestyle: "Lifestyle",
  "jouets-vintage": "Jouets vintage",
  selections: "Sélections",
  looks: "Looks",
  "pieces-histoires": "Pièces & Histoires",
  marques: "Marques",
  epoques: "Époques",
  coulisses: "Coulisses",
  "conseils-guides": "Conseils & Guides",
  drops: "Drops",
};

const pillarBg: Record<string, string> = {
  activites: "linear-gradient(135deg, #5FA68B, #1F3D2E)",
  education: "linear-gradient(135deg, #F0C14B, #E87A3C)",
  lifestyle: "linear-gradient(135deg, #F5E9D3, #F0C14B)",
  "jouets-vintage": "linear-gradient(135deg, #E87A3C, #1F3D2E)",
  selections: "linear-gradient(135deg, #1F3D2E, #5FA68B)",
  looks: "linear-gradient(135deg, #5FA68B, #1F3D2E)",
  marques: "linear-gradient(135deg, #F0C14B, #E87A3C)",
  epoques: "linear-gradient(135deg, #5FA68B, #1F3D2E)",
  "conseils-guides": "linear-gradient(135deg, #F0C14B, #E87A3C)",
};

const cityOrder = ["paris", "lyon", "bordeaux", "marseille"];
const cityLabels: Record<string, string> = {
  paris: "Paris",
  lyon: "Lyon",
  bordeaux: "Bordeaux",
  marseille: "Marseille",
};
const ageOrder = ["1 an", "2 ans", "3 ans"];

const getCity = (tags: string[]) => cityOrder.find((city) => tags.includes(city)) ?? "";
const getAge = (tags: string[]) => ageOrder.find((age) => tags.includes(age)) ?? "";

const cards = filtered.map((article) => ({
  article,
  city: getCity(article.data.tags),
  age: getAge(article.data.tags),
}));

const activityCities = cityOrder.filter((city) => cards.some((card) => card.city === city));
const activityAges = ageOrder.filter((age) => cards.some((card) => card.age === age));
const activityMatrix = activityCities.map((city) => ({
  city,
  label: cityLabels[city],
  articles: activityAges.map((age) => ({
    age,
    match: cards.find((card) => card.city === city && card.age === age),
  })),
}));
---

<BaseLayout
  title={`${label} — Magazine Club Récré`}
  description={`${subtitle} Tous les articles ${label.toLowerCase()} du magazine Club Récré.`}
>
  <header class="container-narrow py-16 text-center">
    <p class="section-label">Catégorie</p>
    <h1 class="font-fraunces font-bold leading-[1.05] tracking-[-0.02em] text-vert-recre" style="font-size: clamp(2.5rem, 6vw, 4rem);">
      {label}
    </h1>
    <p class="text-lg max-w-[680px] mx-auto mt-4 text-noir-reglisse opacity-90">
      {subtitle}
    </p>
  </header>

  {isActivities && (
    <section class="container-narrow pb-12">
      <div class="bg-cream-clair border-2 border-vert-recre rounded-card p-6 md:p-10">
        <div class="text-center max-w-[640px] mx-auto mb-8">
          <p class="section-label">Choisir sa récré</p>
          <h2 class="font-fraunces text-3xl md:text-4xl font-semibold leading-tight text-vert-recre mb-3">
            Ta ville. L'âge de ton enfant. Ton plan du mercredi.
          </h2>
          <p class="text-base text-noir-reglisse opacity-85">
            Sélectionne une ville et un âge, on te ressort le guide qui va bien. Pas de planning, pas de Pinterest — juste des adresses testées.
          </p>
        </div>

        <!-- Filtre Villes (boutons pills) -->
        <div class="mb-6">
          <p class="text-xs uppercase tracking-[0.2em] font-bold text-gris-cartable mb-3 text-center">1. Choisis ta ville</p>
          <div class="flex flex-wrap justify-center gap-2">
            <button
              type="button"
              data-activity-city-btn="all"
              class="filter-pill is-active"
            >
              <span class="text-base mr-1.5">🌍</span> Toutes les villes
            </button>
            {activityCities.map((city) => {
              const cityEmoji = {
                paris: "🥖",
                lyon: "🏛️",
                bordeaux: "🍷",
                marseille: "🌊"
              }[city] ?? "📍";
              return (
                <button
                  type="button"
                  data-activity-city-btn={city}
                  class="filter-pill"
                >
                  <span class="text-base mr-1.5">{cityEmoji}</span> {cityLabels[city]}
                </button>
              );
            })}
          </div>
        </div>

        <!-- Filtre Âges (boutons pills) -->
        <div class="mb-6">
          <p class="text-xs uppercase tracking-[0.2em] font-bold text-gris-cartable mb-3 text-center">2. L'âge de ton enfant</p>
          <div class="flex flex-wrap justify-center gap-2">
            <button
              type="button"
              data-activity-age-btn="all"
              class="filter-pill is-active"
            >
              Tous les âges
            </button>
            {activityAges.map((age) => (
              <button
                type="button"
                data-activity-age-btn={age}
                class="filter-pill"
              >
                {age}
              </button>
            ))}
          </div>
        </div>

        <!-- Compteur + reset -->
        <div class="flex items-center justify-center gap-4 flex-wrap pt-4 border-t border-vert-recre/15">
          <p class="text-sm text-vert-recre font-semibold" data-activity-count>{cards.length} guides disponibles</p>
          <button
            type="button"
            class="btn btn-secondary py-2 px-4 text-[10px]"
            data-activity-reset
          >
            Réinitialiser
          </button>
        </div>

        <!-- Matrice ville × âge (vue d'ensemble visuelle) -->
        <details class="mt-8 group">
          <summary class="cursor-pointer text-xs uppercase tracking-[0.2em] font-bold text-orange-sirop hover:text-vert-recre transition-colors text-center list-none">
            <span class="inline-flex items-center gap-2">
              Voir la matrice complète <span class="group-open:rotate-180 transition-transform">↓</span>
            </span>
          </summary>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mt-6">
            {activityMatrix.map((group) => (
              <div class="bg-cream-gouter border border-vert-recre/20 rounded-card p-4">
                <h3 class="font-fraunces text-2xl font-semibold text-vert-recre mb-3">{group.label}</h3>
                <div class="flex flex-wrap gap-2">
                  {group.articles.map(({ age, match }) => (
                    match ? (
                      <a
                        href={`/journal/${match.article.slug}`}
                        class="badge badge-outline hover:bg-vert-recre hover:text-cream-gouter transition-colors"
                      >
                        {age}
                      </a>
                    ) : (
                      <span class="badge border border-vert-recre/20 text-gris-cartable opacity-50">{age} (bientôt)</span>
                    )
                  ))}
                </div>
              </div>
            ))}
          </div>
        </details>
      </div>
    </section>
  )}

  <section class="container-narrow pb-20">
    {filtered.length === 0 && (
      <p class="text-center text-gris-cartable py-12">Aucun article publié pour le moment dans cette catégorie. Reviens vite ou inscris-toi à la newsletter pour être alerté.</p>
    )}

    {isActivities && (
      <p class="hidden text-center text-gris-cartable py-12" data-activity-empty>
        Rien pour ce combo pour l'instant. Change l'âge ou la ville, comme quand la cassette rembobine.
      </p>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map(({ article, city, age }) => (
        <a
          href={`/journal/${article.slug}`}
          class="card-hover bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 block"
          data-activity-card={isActivities ? "true" : undefined}
          data-city={city}
          data-age={age}
        >
          {article.data.cover ? (
            <div class="aspect-[4/3] overflow-hidden">
              <img src={article.data.cover} alt={article.data.coverAlt ?? article.data.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
          ) : (
            <div class="aspect-[4/3] flex items-center justify-center text-cream-gouter font-fraunces italic text-base text-center p-5"
                 style={`background: ${pillarBg[article.data.pillar] ?? "linear-gradient(135deg, #5FA68B, #1F3D2E)"};`}>
              {article.data.coverAlt ?? article.data.title}
            </div>
          )}
          <div class="p-6">
            {isActivities && city && age ? (
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="badge badge-vert">{cityLabels[city]}</span>
                <span class="badge badge-outline">{age}</span>
              </div>
            ) : (
              <div class="text-[11px] uppercase tracking-[0.25em] text-orange-sirop font-bold mb-2">
                {pillarLabels[article.data.pillar]}
              </div>
            )}
            <h2 class="font-fraunces text-xl font-semibold leading-tight mb-2 text-vert-recre">{article.data.title}</h2>
            <p class="text-sm text-noir-reglisse opacity-80 mb-3">{article.data.description}</p>
            <p class="text-xs text-gris-cartable">
              {article.data.pubDate.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              {article.data.readingTime && ` · ${article.data.readingTime} min`}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>

  {isActivities && (
    <script is:inline>
      const cityButtons = Array.from(document.querySelectorAll("[data-activity-city-btn]"));
      const ageButtons = Array.from(document.querySelectorAll("[data-activity-age-btn]"));
      const resetButton = document.querySelector("[data-activity-reset]");
      const count = document.querySelector("[data-activity-count]");
      const empty = document.querySelector("[data-activity-empty]");
      const cards = Array.from(document.querySelectorAll("[data-activity-card]"));

      let activeCity = "all";
      let activeAge = "all";

      const updateActivityCards = () => {
        let visible = 0;
        cards.forEach((card) => {
          const matchesCity = activeCity === "all" || card.dataset.city === activeCity;
          const matchesAge = activeAge === "all" || card.dataset.age === activeAge;
          const shouldShow = matchesCity && matchesAge;
          card.hidden = !shouldShow;
          if (shouldShow) visible += 1;
        });

        if (count) {
          count.textContent = `${visible} guide${visible > 1 ? "s" : ""} disponible${visible > 1 ? "s" : ""}`;
        }
        if (empty) {
          empty.classList.toggle("hidden", visible !== 0);
        }
      };

      const setActive = (buttons, value, attr) => {
        buttons.forEach((btn) => {
          if (btn.dataset[attr] === value) {
            btn.classList.add("is-active");
          } else {
            btn.classList.remove("is-active");
          }
        });
      };

      cityButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          activeCity = btn.dataset.activityCityBtn;
          setActive(cityButtons, activeCity, "activityCityBtn");
          updateActivityCards();
        });
      });

      ageButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          activeAge = btn.dataset.activityAgeBtn;
          setActive(ageButtons, activeAge, "activityAgeBtn");
          updateActivityCards();
        });
      });

      resetButton?.addEventListener("click", () => {
        activeCity = "all";
        activeAge = "all";
        setActive(cityButtons, "all", "activityCityBtn");
        setActive(ageButtons, "all", "activityAgeBtn");
        updateActivityCards();
      });
    </script>
  )}
</BaseLayout>
