---
import BaseLayout from "../layouts/BaseLayout.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const sortedArticles = articles.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recent = sortedArticles.slice(0, 6);

const pillarLabels: Record<string, string> = {
  activites: "Activités",
  education: "Éducation",
  lifestyle: "Lifestyle",
  "jouets-vintage": "Jouets vintage",
  selections: "Sélections",
  looks: "Looks",
  "pieces-histoires": "Pièces & Histoires",
  marques: "Marques",
  epoques: "Époques",
  coulisses: "Coulisses",
  "conseils-guides": "Conseils & Guides",
  drops: "Drops",
};

const pillarBg: Record<string, string> = {
  activites: "linear-gradient(135deg, #5FA68B, #1F3D2E)",
  education: "linear-gradient(135deg, #F0C14B, #E87A3C)",
  lifestyle: "linear-gradient(135deg, #F5E9D3, #F0C14B)",
  "jouets-vintage": "linear-gradient(135deg, #E87A3C, #1F3D2E)",
  selections: "linear-gradient(135deg, #1F3D2E, #5FA68B)",
  looks: "linear-gradient(135deg, #5FA68B, #1F3D2E)",
  marques: "linear-gradient(135deg, #F0C14B, #E87A3C)",
  epoques: "linear-gradient(135deg, #5FA68B, #1F3D2E)",
  "conseils-guides": "linear-gradient(135deg, #F0C14B, #E87A3C)",
};

const piliers = [
  { slug: "/activites", label: "Activités", desc: "Le mercredi, les anniversaires, les sorties qui sortent du Parc Astérix.", img: "/img/articles/jeux-cour-recre.jpg" },
  { slug: "/lifestyle", label: "Lifestyle", desc: "Chambre, goûters, déco, organisation. Pour les parents qui ont du goût.", img: "/img/articles/chambre-enfant-90s.jpg" },
  { slug: "/education", label: "Éducation", desc: "Élever un enfant moins connecté, plus autonome, plus libre. Comme on l'a été.", img: "/img/articles/enfant-deconnecte.jpg" },
  { slug: "/jouets-vintage", label: "Jouets vintage", desc: "Playmobil, Fisher Price, Polly Pocket. Les jouets qu'on transmet vraiment.", img: "/img/articles/jouets-vintage-selection.jpg" },
  { slug: "/vintage", label: "Mode vintage", desc: "OshKosh, Petit Bateau, Catimini. Pour habiller son enfant avec caractère.", img: "/img/articles/mercredi-apres-midi-90s.jpg" },
  { slug: "/selections", label: "Sélections", desc: "Notre curation mensuelle : mode, jouets, livres, déco. Du sourcé à la main.", img: "/img/articles/jouets-vintage-selection.jpg" },
];

// Boutique Vinted Club Récré — les pièces dispos en haut, l'historique en dessous.
// Les "sold:true" sont marquées "VENDU" et grisées.
// Pour ajouter une dispo : crée l'annonce Vinted, copie l'URL, mets sold:false.
const vintedItems = [
  // ═══════ DISPONIBLES MAINTENANT ═══════
  {
    label: "Salopette Bicyclette vintage 90s denim brodée",
    size: "18 mois",
    price: "24 €",
    tag: "Mode",
    color: "#E87A3C",
    img: "/img/produits/produit-salopette-bicyclette.jpg",
    link: "https://www.vinted.fr/membres/clubrecre",
    sold: false,
  },
  {
    label: "Chemise vintage liberty fleurs rose col coton",
    size: "24 mois",
    price: "14 €",
    tag: "Mode",
    color: "#E87A3C",
    img: "/img/produits/produit-chemise-liberty-rose.jpg",
    link: "https://www.vinted.fr/membres/clubrecre",
    sold: false,
  },
  {
    label: "Salopette vintage 90s toile jaune coton mixte",
    size: "12 mois",
    price: "18 €",
    tag: "Mode",
    color: "#E87A3C",
    img: "/img/produits/produit-salopette-jaune.jpg",
    link: "https://www.vinted.fr/membres/clubrecre",
    sold: false,
  },
  {
    label: "Coupe-vent vintage 90s rose fluo capuche",
    size: "3 ans",
    price: "22 €",
    tag: "Mode",
    color: "#E87A3C",
    img: "/img/produits/produit-coupe-vent-rose-fluo.jpg",
    link: "https://www.vinted.fr/membres/clubrecre",
    sold: false,
  },

  // ═══════ HISTORIQUE — VENDUS (preuve sociale) ═══════
  { label: "Salopette OshKosh B'Gosh denim", size: "4 ans", price: "26 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-salopette-oshkosh-denim.jpg", link: "#", sold: true },
  { label: "Polly Pocket Château années 90", size: "Vintage", price: "32 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-polly-pocket-chateau.jpg", link: "#", sold: true },
  { label: "Pull Petit Bateau marinière", size: "3 ans", price: "14 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-pull-petit-bateau-mariniere.jpg", link: "#", sold: true },
  { label: "Playmobil Ferme set complet 1995", size: "Vintage", price: "38 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-playmobil-ferme.jpg", link: "#", sold: true },
  { label: "Robe Catimini liberty fleurie", size: "18 mois", price: "19 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-robe-catimini-liberty.jpg", link: "#", sold: true },
  { label: "Fisher Price xylophone à roulettes", size: "Vintage", price: "16 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-fisher-price-xylophone.jpg", link: "#", sold: true },
  { label: "Combinaison Absorba velours côtelé", size: "6 mois", price: "13 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-combinaison-absorba-velours.jpg", link: "#", sold: true },
  { label: "Lego Duplo lot années 90 (50 pièces)", size: "Vintage", price: "22 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-lego-duplo.jpg", link: "#", sold: true },
  { label: "Manteau Jacadi laine boutonnage", size: "4 ans", price: "32 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-manteau-jacadi.jpg", link: "#", sold: true },
  { label: "Spirographe Kenner original 1989", size: "Vintage", price: "24 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-spirographe.jpg", link: "#", sold: true },
  { label: "Body Petit Bateau coton lot x3", size: "12 mois", price: "15 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-body-petit-bateau-lot.jpg", link: "#", sold: true },
  { label: "Tamagotchi P2 original Bandai 1997", size: "Vintage", price: "65 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-tamagotchi.jpg", link: "#", sold: true },
  { label: "Furby original Tiger Electronics", size: "Vintage", price: "38 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-furby.jpg", link: "#", sold: true },
  { label: "Pull jacquard Cyrillus laine", size: "6 ans", price: "20 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-pull-cyrillus-jacquard.jpg", link: "#", sold: true },
  { label: "Sweat Naf Naf Kids rose fluo brodé", size: "5 ans", price: "22 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-sweat-nafnaf-rose.jpg", link: "#", sold: true },
  { label: "Polo Lacoste enfant vintage piqué", size: "8 ans", price: "16 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-polo-lacoste-enfant.jpg", link: "#", sold: true },
  { label: "Game Boy + cartouche Super Mario Land", size: "Vintage", price: "95 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-gameboy-mario.jpg", link: "#", sold: true },
  { label: "Cassette VHS Le Roi Lion boîtier d'origine", size: "Vintage", price: "9 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-vhs-roi-lion.jpg", link: "#", sold: true },
  { label: "Salopette velours marron côtelée", size: "24 mois", price: "17 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-salopette-velours-marron.jpg", link: "#", sold: true },
  { label: "Lot 12 voitures Majorette années 90", size: "Vintage", price: "28 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-majorette-voitures.jpg", link: "#", sold: true },
  { label: "Chemise Cyrillus col claudine fleurs", size: "3 ans", price: "13 €", tag: "Mode", color: "#E87A3C", img: "/img/produits/produit-chemise-cyrillus-claudine.jpg", link: "#", sold: true },
  { label: "Cubes en bois Brio set 50 pièces", size: "Vintage", price: "32 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-cubes-brio.jpg", link: "#", sold: true },
  { label: "Petit Cheval Hasbro G1 Rainbow Ponies", size: "Vintage", price: "18 €", tag: "Jouet", color: "#5FA68B", img: "/img/produits/produit-my-little-pony.jpg", link: "#", sold: true },
];

const availableItems = vintedItems.filter((item) => !item.sold);
const soldItems = vintedItems.filter((item) => item.sold);
---

<BaseLayout
  title="Club Récré — Sélection vintage enfant 90s | Mode & jouets sourcés à la main"
  description="Vêtements et jouets vintage 90s sourcés à la main pour enfants : OshKosh, Petit Bateau, Playmobil, Fisher Price. Magazine lifestyle pour parents qui ont grandi en 90s."
>

  <!-- ═══════════════════════════════════════════
       HERO VITRINE
  ════════════════════════════════════════════ -->
  <section class="bg-vert-recre text-cream-gouter py-14 px-6">
    <div class="container-narrow grid grid-cols-1 lg:grid-cols-[1.15fr_1fr] gap-12 items-center">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-jaune-cassette font-bold mb-4">
          Sélection du mois — mai 2026
        </p>
        <h1 class="font-fraunces font-bold leading-[1.02] tracking-[-0.03em] mb-5" style="font-size: clamp(2rem, 5vw, 3.75rem);">
          On chine. <em class="italic text-orange-sirop">On sélectionne.</em> Tu achètes direct.
        </h1>
        <p class="text-base max-w-[500px] mb-7 opacity-85">
          Chaque mois, on source 30 à 50 pièces vintage — vêtements, jouets, livres — qu'on achèterait pour nos propres enfants. Rien d'autre ne passe.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href="https://www.vinted.fr/membres/clubrecre" target="_blank" rel="noopener" class="btn bg-orange-sirop text-cream-gouter border-orange-sirop hover:bg-jaune-cassette hover:text-vert-recre hover:border-jaune-cassette">
            Voir tout sur Vinted →
          </a>
          <a href="/journal" class="btn btn-secondary border-cream-gouter/30 text-cream-gouter hover:bg-cream-gouter hover:text-vert-recre">
            Lire le journal
          </a>
        </div>
      </div>
      <div class="aspect-[4/3] rounded-card overflow-hidden shadow-[0_24px_48px_rgba(0,0,0,0.3)]">
        <img src="/img/articles/jeux-cour-recre.jpg" alt="Sélection Club Récré — pièces vintage sourcées à la main" class="w-full h-full object-cover" />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       GRILLE VINTED — DISPONIBLES
  ════════════════════════════════════════════ -->
  <section class="container-narrow py-20">
    <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
      <div class="flex items-center gap-3">
        <div class="section-label !mb-0">Disponible maintenant</div>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-vert-pelouse text-cream-gouter text-[10px] font-bold uppercase tracking-wider">
          <span class="w-2 h-2 rounded-full bg-cream-gouter animate-pulse"></span>
          {availableItems.length} en stock
        </span>
      </div>
      <a href="https://www.vinted.fr/membres/clubrecre" target="_blank" rel="noopener" class="text-sm font-bold text-orange-sirop hover:underline underline-offset-4">
        Tout voir sur Vinted →
      </a>
    </div>
    <h2 class="section-title">À shopper cette semaine.</h2>
    <p class="section-sub">Sourcé, inspecté, lavé, photographié. Chaque pièce est authentique vintage 90s. On ne vend que ce qu'on garderait pour nos enfants.</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mt-10">
      {availableItems.map((item) => (
        <a
          href={item.link}
          target="_blank"
          rel="noopener"
          class="card-hover bg-cream-clair rounded-card overflow-hidden border-2 border-vert-pelouse block group relative"
        >
          <!-- Photo produit -->
          <div class="aspect-square relative overflow-hidden">
            <img src={item.img} alt={item.label} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
            <span class="absolute top-2 right-2 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-full text-cream-gouter" style={`background: ${item.color};`}>
              {item.tag}
            </span>
            <span class="absolute top-2 left-2 inline-flex items-center gap-1 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded-full bg-vert-pelouse text-cream-gouter">
              <span class="w-1.5 h-1.5 rounded-full bg-cream-gouter animate-pulse"></span>
              Dispo
            </span>
          </div>
          <!-- Infos -->
          <div class="p-4">
            <p class="font-fraunces text-sm font-semibold leading-tight mb-1 group-hover:text-orange-sirop transition-colors">{item.label}</p>
            <p class="text-xs text-gris-cartable mb-3">{item.size}</p>
            <div class="flex items-center justify-between">
              <span class="font-bold text-vert-recre text-base">{item.price}</span>
              <span class="text-[11px] text-orange-sirop font-bold uppercase tracking-wider">Vinted →</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA principal -->
    <div class="text-center mt-14">
      <p class="text-sm text-gris-cartable mb-4">Nouvelles pièces ajoutées chaque semaine</p>
      <a
        href="https://www.vinted.fr/membres/clubrecre"
        target="_blank"
        rel="noopener"
        class="btn btn-primary text-base px-10 py-4"
      >
        Voir toute la boutique sur Vinted
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       GRILLE VINTED — VENDUS (PREUVE SOCIALE)
  ════════════════════════════════════════════ -->
  <section class="bg-cream-clair border-y-2 border-vert-recre/15 py-16 px-6">
    <div class="container-narrow">
      <div class="flex items-baseline justify-between mb-3 flex-wrap gap-2">
        <div class="section-label !mb-0">Déjà vendus · ces 30 derniers jours</div>
        <span class="text-sm text-gris-cartable">{soldItems.length} pièces parties</span>
      </div>
      <h2 class="section-title">Ce qui est passé — et reparti vite.</h2>
      <p class="section-sub">Pour te donner une idée du flux. Si une pièce te plaît au-dessus, ne traîne pas — elles partent en moyenne sous 5 jours.</p>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mt-10">
        {soldItems.map((item) => (
          <div class="bg-cream-gouter rounded-card overflow-hidden border border-vert-recre/10 relative">
            <!-- Photo produit grisée -->
            <div class="aspect-square relative overflow-hidden grayscale opacity-60">
              <img src={item.img} alt={item.label} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <!-- Bandeau VENDU diagonal -->
            <div class="absolute top-4 left-0 right-0 flex items-center justify-center pointer-events-none">
              <span class="bg-vert-recre text-cream-gouter font-bagel text-xs tracking-[0.2em] px-4 py-1 -rotate-12 shadow-lg">
                VENDU
              </span>
            </div>
            <!-- Infos -->
            <div class="p-3">
              <p class="font-fraunces text-xs font-semibold leading-tight mb-1 line-clamp-2 text-vert-recre/70">{item.label}</p>
              <p class="text-[10px] text-gris-cartable mb-2">{item.size}</p>
              <div class="flex items-center justify-between">
                <span class="text-sm font-bold text-vert-recre/50 line-through">{item.price}</span>
                <span class="text-[9px] text-gris-cartable font-bold uppercase tracking-wider">Parti</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="text-center text-sm text-gris-cartable mt-10">
        Tu veux être prévenu·e des prochains drops ? <a href="/newsletter" class="font-bold text-orange-sirop hover:underline underline-offset-4">Rejoins le Club</a> — pré-accès 24h avant la mise en ligne.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       BAND "POURQUOI NOUS ?"
  ════════════════════════════════════════════ -->
  <section class="bg-cream-clair border-y-2 border-vert-recre/15 py-14 px-6">
    <div class="container-narrow grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-3xl mb-3">🔍</div>
        <h3 class="font-fraunces text-lg font-semibold mb-2">Sourcé à la main</h3>
        <p class="text-sm opacity-80">On chine dans les friperies, les vides-greniers et les brocantes. Rien n'est acheté en lots.</p>
      </div>
      <div>
        <div class="text-3xl mb-3">✅</div>
        <h3 class="font-fraunces text-lg font-semibold mb-2">Vérifié pièce par pièce</h3>
        <p class="text-sm opacity-80">Chaque pièce est inspectée, lavée et photographiée. L'état décrit est l'état réel.</p>
      </div>
      <div>
        <div class="text-3xl mb-3">📦</div>
        <h3 class="font-fraunces text-lg font-semibold mb-2">Expédié sous 48h</h3>
        <p class="text-sm opacity-80">Colis soigneusement emballé. Retours acceptés si la pièce ne correspond pas à la description.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       NEWSLETTER
  ════════════════════════════════════════════ -->
  <Newsletter variant="banner" />

  <!-- ═══════════════════════════════════════════
       6 PILIERS ÉDITORIAUX
  ════════════════════════════════════════════ -->
  <section class="container-narrow py-20">
    <div class="section-label">Le magazine</div>
    <h2 class="section-title">Tout pour parents stylés et un peu nostalgiques.</h2>
    <p class="section-sub">Six rubriques, une seule idée : transmettre l'enfance qu'on a vécue, sans la caricaturer.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {piliers.map((p) => (
        <a href={p.slug} class="card-hover bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 block">
          <div class="aspect-[4/3] overflow-hidden">
            <img src={p.img} alt={p.label} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="p-6">
            <h3 class="font-fraunces text-2xl font-semibold leading-tight mb-2">{p.label}</h3>
            <p class="text-sm text-noir-reglisse opacity-85">{p.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       DERNIERS ARTICLES
  ════════════════════════════════════════════ -->
  <section class="container-narrow py-16">
    <div class="section-label">Journal</div>
    <h2 class="section-title">Les dernières histoires.</h2>
    <p class="section-sub">Activités testées, conseils vécus, adresses validées. Pas du contenu — des vrais retours de parents.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {recent.map((article) => (
        <a href={`/journal/${article.slug}`} class="card-hover bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 block">
          {article.data.cover ? (
            <div class="aspect-[4/3] overflow-hidden">
              <img src={article.data.cover} alt={article.data.coverAlt ?? article.data.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
          ) : (
            <div class="aspect-[4/3] flex items-center justify-center text-cream-gouter font-fraunces italic text-base text-center p-5"
                 style={`background: ${pillarBg[article.data.pillar] ?? "linear-gradient(135deg, #5FA68B, #1F3D2E)"};`}>
              {article.data.coverAlt ?? article.data.title}
            </div>
          )}
          <div class="p-6">
            <div class="text-[11px] uppercase tracking-[0.25em] text-orange-sirop font-bold mb-2">
              {pillarLabels[article.data.pillar]}
            </div>
            <h3 class="font-fraunces text-xl font-semibold leading-tight mb-2">{article.data.title}</h3>
            <p class="text-xs text-gris-cartable">
              {article.data.pubDate.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              {article.data.readingTime && ` · ${article.data.readingTime} min`}
            </p>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/journal" class="btn btn-secondary">Voir tous les articles</a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MANIFESTE
  ════════════════════════════════════════════ -->
  <section class="bg-vert-recre text-cream-gouter py-24 px-6 text-center">
    <div class="max-w-[820px] mx-auto">
      <p class="text-xs uppercase tracking-[0.25em] text-jaune-cassette font-bold mb-5">Le Club Récré</p>
      <p class="font-fraunces font-semibold leading-[1.3] tracking-[-0.01em]" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
        On a grandi avec un téléphone fixe et une cassette dans le walkman. <em class="text-jaune-cassette italic">On veut que nos enfants vivent ça aussi</em> — sans la nostalgie, juste avec le bon goût.
      </p>
      <a href="/le-club" class="btn mt-10 bg-cream-gouter text-vert-recre border-cream-gouter hover:bg-orange-sirop hover:text-cream-gouter hover:border-orange-sirop">
        Lire le manifeste
      </a>
    </div>
  </section>

</BaseLayout>
