---
import BaseLayout from "../layouts/BaseLayout.astro";
import Newsletter from "../components/Newsletter.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const sortedArticles = articles.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = sortedArticles.find((a) => a.data.featured) ?? sortedArticles[0];
const recent = sortedArticles.slice(0, 6);

const pillarLabels: Record<string, string> = {
  looks: "Looks",
  "pieces-histoires": "Pièces & Histoires",
  marques: "Marques",
  epoques: "Époques",
  coulisses: "Coulisses",
  "conseils-guides": "Conseils",
  drops: "Drops",
};

const marquesPhares = [
  { slug: "oshkosh-bgosh", name: "OshKosh B'Gosh", country: "USA" },
  { slug: "petit-bateau", name: "Petit Bateau", country: "France" },
  { slug: "catimini", name: "Catimini", country: "France" },
  { slug: "cyrillus", name: "Cyrillus", country: "France" },
  { slug: "sergent-major", name: "Sergent Major", country: "France" },
  { slug: "jacadi", name: "Jacadi", country: "France" },
  { slug: "dpam", name: "DPAM", country: "France" },
  { slug: "naf-naf-kids", name: "Naf Naf Kids", country: "France" },
  { slug: "lacoste-enfant", name: "Lacoste Enfant", country: "France" },
  { slug: "disney-vintage", name: "Disney Vintage", country: "USA" },
  { slug: "kookai-kids", name: "Kookaï Kids", country: "France" },
  { slug: "marese", name: "Marèse", country: "France" },
];

const epoquesAmbiance = [
  { slug: "cour-de-recre", name: "Cour de récré", desc: "Sweats à logos, vestes coupe-vent, t-shirts d'équipe." },
  { slug: "ete-90", name: "Été 90", desc: "Couleurs fluo, salopettes courtes, sandales de plage." },
  { slug: "gouter-anniversaire", name: "Goûter d'anniversaire", desc: "Chemises à carreaux, robes à smocks, polos rayés." },
  { slug: "mercredi-apres-midi", name: "Mercredi après-midi", desc: "Joggings velours, sweats doux, t-shirts série télé." },
  { slug: "dimanche-hiver", name: "Dimanche d'hiver", desc: "Pulls jacquard, manteaux à capuche, écharpes tricotées." },
  { slug: "premier-jour-ecole", name: "Premier jour d'école", desc: "Cartable, jean propre, sweat. Le grand classique." },
];
---

<BaseLayout
  title="Club Récré — Mode vintage enfant 90s, looks, marques et conseils"
  description="Magazine vintage enfant 90s. Looks complets, guides marques, conseils pour habiller son enfant en style années 90 sans tomber dans le déguisement."
>
  <!-- HERO -->
  <section class="container-narrow grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-12 items-center py-16">
    <div>
      <p class="text-xs uppercase tracking-[0.25em] text-orange-sirop font-bold mb-4">
        Drop de Mai · La Grande Récré
      </p>
      <h1 class="font-fraunces font-bold leading-[1.02] tracking-[-0.03em] mb-6" style="font-size: clamp(2.5rem, 6vw, 4.875rem);">
        Une enfance <em class="italic text-orange-sirop">libre</em>, en 30 pièces.
      </h1>
      <p class="text-lg max-w-[480px] mb-8 opacity-90">
        Le drop de mai est en ligne. Salopettes OshKosh 1989, sweats Disney d'origine, vestes coupe-vent fluo. Pour les enfants qui jouent dehors, pas pour ceux qu'on prend en photo.
      </p>
      <div class="flex gap-3 flex-wrap">
        <a href="/drops" class="btn btn-primary">Voir le drop</a>
        <a href="/le-club" class="btn btn-secondary">Rejoindre le Club</a>
      </div>
    </div>

    <div class="aspect-[4/5] rounded-card relative overflow-hidden flex items-end p-8 text-cream-gouter shadow-[0_24px_48px_rgba(31,61,46,0.18)]"
         style="background: radial-gradient(circle at 30% 30%, rgba(245,233,211,0.4) 0%, transparent 50%), linear-gradient(135deg, #5FA68B 0%, #F0C14B 50%, #E87A3C 100%);">
      <div class="absolute top-6 left-6 w-[90px] h-[90px] rounded-full bg-vert-recre text-jaune-cassette flex items-center justify-center font-bagel text-[14px] text-center leading-tight transform -rotate-12">
        DROP<br>DU<br>MOIS
      </div>
      <p class="font-fraunces italic text-lg max-w-[280px]">"On a 6 ans, on est libres, on a des coquelicots aux genoux."</p>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <Newsletter variant="banner" />

  <!-- DERNIERS ARTICLES -->
  <section class="container-narrow py-20">
    <div class="section-label">Journal</div>
    <h2 class="section-title">Comment bien habiller son enfant en vintage 90s.</h2>
    <p class="section-sub">Looks, pièces, marques, époques, conseils. Une nouvelle entrée toutes les semaines.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {recent.map((article) => (
        <a href={`/journal/${article.slug}`} class="card-hover bg-cream-clair rounded-card overflow-hidden border border-vert-recre/10 block">
          <div class="aspect-[4/3] flex items-center justify-center text-cream-gouter font-fraunces italic text-base text-center p-5"
               style={article.data.pillar === "marques" ? "background: linear-gradient(135deg, #d4a373, #b87333);" :
                      article.data.pillar === "epoques" ? "background: linear-gradient(135deg, #5FA68B, #1F3D2E);" :
                      article.data.pillar === "conseils-guides" ? "background: linear-gradient(135deg, #F0C14B, #E87A3C); color: #1F3D2E;" :
                      "background: linear-gradient(135deg, #5FA68B, #1F3D2E);"}>
            {article.data.coverAlt ?? article.data.title}
          </div>
          <div class="p-6">
            <div class="text-[11px] uppercase tracking-[0.25em] text-orange-sirop font-bold mb-2">
              {pillarLabels[article.data.pillar]}
            </div>
            <h3 class="font-fraunces text-xl font-semibold leading-tight mb-2">{article.data.title}</h3>
            <p class="text-xs text-gris-cartable">
              {article.data.pubDate.toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" })}
              {article.data.readingTime && ` · ${article.data.readingTime} min`}
            </p>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/journal" class="btn btn-secondary">Voir tous les articles</a>
    </div>
  </section>

  <!-- MARQUES VINTAGE -->
  <section class="bg-cream-clair border-y-2 border-vert-recre py-16 px-6">
    <div class="container-narrow">
      <div class="section-label">Les marques du Club</div>
      <h2 class="section-title">Les noms qui ont fait notre enfance.</h2>
      <p class="section-sub">Notre encyclopédie des marques vintage enfant des années 80-90.</p>

      <div class="grid grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4 mt-10">
        {marquesPhares.map((m) => (
          <a href={`/marques/${m.slug}`} class="aspect-square bg-cream-gouter rounded-card flex items-center justify-center font-bagel text-sm text-center p-3 leading-tight text-vert-recre transition-all hover:bg-vert-recre hover:text-cream-gouter hover:-translate-y-1 border-2 border-transparent hover:border-vert-recre">
            {m.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- EPOQUES -->
  <section class="container-narrow py-20">
    <div class="section-label">Époques & ambiances</div>
    <h2 class="section-title">Choisis ton époque.</h2>
    <p class="section-sub">Les pièces, les looks et les histoires regroupés par moment de vie.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-10">
      {epoquesAmbiance.map((e, i) => (
        <a href={`/epoques/${e.slug}`} class="aspect-[5/4] rounded-card p-6 flex flex-col justify-end text-cream-gouter cursor-pointer transition-all hover:-translate-y-1"
           style={
             i === 0 ? "background: linear-gradient(135deg, #5FA68B 0%, #1F3D2E 100%);" :
             i === 1 ? "background: linear-gradient(135deg, #F0C14B 0%, #E87A3C 100%); color: #1F3D2E;" :
             i === 2 ? "background: linear-gradient(135deg, #b87333 0%, #8b4513 100%);" :
             i === 3 ? "background: linear-gradient(135deg, #d4a373 0%, #E87A3C 100%);" :
             i === 4 ? "background: linear-gradient(135deg, #1F3D2E 0%, #181818 100%);" :
             "background: linear-gradient(135deg, #E87A3C 0%, #F0C14B 100%); color: #1F3D2E;"
           }>
          <h3 class="font-fraunces text-2xl font-semibold leading-tight mb-2">{e.name}</h3>
          <p class="text-sm opacity-90">{e.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- MANIFESTO BAND -->
  <section class="bg-vert-recre text-cream-gouter py-24 px-6 text-center">
    <div class="max-w-[760px] mx-auto">
      <p class="text-xs uppercase tracking-[0.25em] text-jaune-cassette font-bold mb-5">Le Club Récré</p>
      <p class="font-fraunces font-semibold leading-[1.3] tracking-[-0.01em]" style="font-size: clamp(1.5rem, 3vw, 2.25rem);">
        Pas une friperie. Pas une marque sage. <em class="text-jaune-cassette italic">Une marque d'image et de nostalgie</em> qui vend une enfance libre, une esthétique 90s et un imaginaire collectif.
      </p>
      <a href="/le-club" class="btn mt-10 bg-cream-gouter text-vert-recre border-cream-gouter hover:bg-orange-sirop hover:text-cream-gouter hover:border-orange-sirop">
        Lire le manifeste
      </a>
    </div>
  </section>
</BaseLayout>
