---
const pathname = Astro.url.pathname;
const isActive = (path: string) => pathname.startsWith(path);

const links = [
  { href: "/activites", label: "Activités" },
  { href: "/lifestyle", label: "Lifestyle" },
  { href: "/vintage", label: "Vintage" },
  { href: "/education", label: "Conseils" },
];

const VINTED_URL = "https://www.vinted.fr/membres/clubrecre";
---

<header class="sticky top-0 z-50 bg-cream-gouter border-b-2 border-vert-recre">
  <div class="container-narrow flex items-center justify-between gap-4 py-3">
    <a href="/" class="club-wordmark club-wordmark--compact shrink-0" aria-label="Club Récré, accueil">
      <span class="club-wordmark__club">Club</span>
      <span class="club-wordmark__recre">Récré</span>
    </a>

    <nav class="flex items-center gap-3 lg:gap-5">
      <ul class="hidden sm:flex gap-3 lg:gap-5 list-none flex-wrap justify-end items-center">
        {
          links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  "text-[11px] lg:text-sm font-semibold uppercase tracking-[0.12em] transition-colors hover:text-orange-sirop relative whitespace-nowrap",
                  isActive(href) && "text-orange-sirop after:absolute after:-bottom-2 after:left-0 after:right-0 after:h-[3px] after:bg-orange-sirop after:rounded-sm",
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- CTA Boutique -->
      <a
        href={VINTED_URL}
        target="_blank"
        rel="noopener"
        class="shrink-0 inline-flex items-center gap-1.5 px-4 py-2 rounded-btn bg-orange-sirop text-cream-gouter text-[11px] lg:text-sm font-bold uppercase tracking-[0.1em] border-2 border-orange-sirop hover:bg-jaune-cassette hover:text-vert-recre hover:border-jaune-cassette transition-all duration-200 whitespace-nowrap"
      >
        <span>🛍️</span> La Boutique
      </a>
    </nav>
  </div>
</header>
